# ── Mobile app build-time configuration ──────────────────────────────────────
# EXPO_PUBLIC_* variables are safe to embed: they are not secrets.
# Do NOT add EXPO_PUBLIC_APP_SECRET — that would ship the secret in the bundle.

# Production backend URL (used as the default for fresh installs).
# Override this per-environment by editing this file before building.
EXPO_PUBLIC_BACKEND_URL=https://your-app.up.railway.app
