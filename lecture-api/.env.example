# Environment variables — copy this file to .env and fill in your values
# NEVER commit .env to git

# Your secret key — the mobile app sends this in x-app-key header
# Generate anything random, e.g.: openssl rand -hex 32
APP_SECRET=change_me_to_a_long_random_string

# Third-party API keys — these stay on the server only
ASSEMBLYAI_API_KEY=your_assemblyai_key_here
OPENAI_API_KEY=your_openai_key_here

# Server config
PORT=3000
NODE_ENV=development
